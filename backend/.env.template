# ============================================================
# AgentFlow Article Publishing - environment template
# Copy to .env and fill in the values you need.
#
# IMPORTANT: this template is configured for PRODUCTION defaults.
# Mock fixtures must be opted into explicitly — the previous
# "MOCK_LLM=true by default" behaviour leaked fake URLs (e.g.
# https://medium.com/@mock/...) into publish_history.jsonl.
# ============================================================

# ---------- LLM (core) ----------
# Set MOCK_LLM=true ONLY when you're running unit tests / smoke tests
# without real API keys. In that mode D0/D1/D2/D3 use deterministic
# fixtures from agentflow/shared/mocks/. Production = false.
MOCK_LLM=false

# ---------- Publisher mock toggle (DECOUPLED from MOCK_LLM) ----------
# When true, D4 publishers (medium / ghost / linkedin / twitter / webhook)
# return fake "https://*mock*" URLs instead of calling real platforms.
# This is decoupled from MOCK_LLM so dev runs can use mock LLM without
# polluting publish_history.jsonl. Production = false (or unset).
AGENTFLOW_MOCK_PUBLISHERS=false

# When true, `af review-publish-mark` will accept obvious mock/test URLs
# (https://*mock*, *.test/*, e2e-*, localhost, etc.). Only set during
# smoke testing — production should leave this unset / false.
AGENTFLOW_ALLOW_MOCK_URLS=false

# ---------- Generation (D0/D1/D2/D3 chat) ----------
# Provider selection:
#   - "kimi"    → Moonshot Kimi K2.6 via https://api.moonshot.cn/v1 (OpenAI-compat)
#   - "claude"  → Anthropic Claude Opus 4.7
#   - "auto"    → prefer Kimi if MOONSHOT_API_KEY set, else Claude
GENERATION_PROVIDER=auto
# When true, a Kimi request that still fails after retries on rate-limit /
# transient upstream errors will retry once via Claude (if ANTHROPIC_API_KEY is set).
GENERATION_PROVIDER_FALLBACK=false

# Kimi / Moonshot — PRIMARY generation provider in v0.1.
# Get a key at https://platform.moonshot.cn/console/api-keys
#
# Model choice:
#   - "moonshot-v1-32k"  (DEFAULT) — fast, non-thinking, stable JSON output.
#                        Best for D1/D2 structured calls. ~2s typical latency.
#   - "moonshot-v1-8k"   — same family, smaller context.
#   - "moonshot-v1-128k" — same family, huge context, slower.
#   - "kimi-k2.6"        — the flagship "thinking" model. HIGHER QUALITY on
#                          reasoning-heavy tasks, but spends max_tokens budget
#                          on internal reasoning (reasoning_content). For
#                          D1/D2 JSON calls this causes content truncation
#                          unless max_tokens is bumped well above 4000.
#                          Not recommended as global default.
#   - "kimi-k2.5"        — previous-gen thinking model.
MOONSHOT_API_KEY=
MOONSHOT_MODEL=moonshot-v1-32k
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Claude — fallback generation provider. Leave blank unless you want to
# route generation through Anthropic instead of Moonshot.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ---------- Embeddings (D1 clustering) ----------
# Provider selection:
#   - "jina"   → Jina AI (recommended; 10M tokens one-time free, then ~$0.02/1M)
#   - "openai" → OpenAI text-embedding-3-small
#   - "auto"   → prefer Jina if JINA_API_KEY set, else OpenAI
EMBEDDING_PROVIDER=auto

# Jina (primary embedding provider in v0.1)
# Get a key at https://jina.ai/?sui=apikey (no credit card for the 10M free tokens).
# Free tokens are a one-time bonus per key, shared across all Jina APIs
# (embeddings/reader/reranker). After depletion: pay-as-you-go at ~$0.02/1M.
# Expected usage for this project: ~15K tokens per hotspots scan → 10M covers
# ~22 months of daily scans.
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-embeddings-v3
JINA_EMBEDDING_TASK=text-matching
JINA_EMBEDDING_DIM=1024

# OpenAI embeddings — fallback only. Keep blank unless you want to use OpenAI
# instead of Jina. Kimi/Moonshot does NOT offer embeddings, so this stays as
# the only "Western big lab" fallback.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------- Data collection (D1) ----------
# Twitter / X — Bearer token for KOL monitoring
TWITTER_BEARER_TOKEN=

# ---------- Local media helpers ----------
# Optional local image library root for `af image-auto-resolve`.
AGENTFLOW_IMAGE_LIBRARY=~/Pictures/agentflow
# Optional generated image output root for `af image-generate`.
AGENTFLOW_GENERATED_IMAGE_DIR=
# Optional one-off visual bias when the active topic profile has no
# publisher_account.image_prompt_hints configured.
AGENTFLOW_IMAGE_DOMAIN_HINT=

# ---------- Image generation (AtlasCloud relay -> GPT Image 2) ----------
ATLASCLOUD_API_KEY=
ATLASCLOUD_BASE_URL=https://api.atlascloud.ai
ATLASCLOUD_IMAGE_MODEL=openai/gpt-image-2-developer/text-to-image
ATLASCLOUD_IMAGE_SIZE=16:9
ATLASCLOUD_IMAGE_RESOLUTION=2k
ATLASCLOUD_POLL_INTERVAL_SECONDS=3
ATLASCLOUD_TIMEOUT_SECONDS=180

# HackerNews / RSS have no auth requirement.

# DBSCAN clustering knobs for the hotspot pipeline.
# Spec default eps=0.35 clusters Jina-v3 embeddings too tightly on mixed
# Twitter/RSS content (1-2 clusters out of 200+ signals). Loosen to 0.45-0.55
# for 5-10 clusters per day. Raise if you want fewer/broader topics, lower
# if you want tighter/more topic buckets.
D1_DBSCAN_EPS=0.5
D1_DBSCAN_MIN_SAMPLES=2
D1_VIEWPOINT_CONCURRENCY=2

# Default topic/profile id for profile-aware commands when neither --profile
# nor the current intent provides one. Leave blank to force explicit selection.
AGENTFLOW_DEFAULT_TOPIC_PROFILE=

# ---------- Publishing (D4) ----------
# Ghost — PRIMARY target in v0.1.
# Admin API URL: your Ghost site URL (e.g. https://yoursite.ghost.io)
# Admin API Key: from Settings → Integrations → Add custom integration.
#   Format: "<24hex>:<hex_secret>" (with colon). NOT the 26-hex Content key.
GHOST_ADMIN_API_URL=
GHOST_ADMIN_API_KEY=

# LinkedIn — OAuth 2.0 access token + person URN.
# Requires a LinkedIn developer app + OAuth flow (30-60 min one-time setup).
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Medium — DEPRECATED. Medium closed their public API to new integrations on
# 2025-01-01. Only accounts that generated an integration token before that
# date can still use this. New accounts will not see the "Integration tokens"
# section in settings. Leave blank unless you already hold a legacy token.
MEDIUM_INTEGRATION_TOKEN=

# Ghost post status: "published" (live), "draft" (hidden), or "scheduled".
# Default is "published". Useful "draft" for smoke tests.
GHOST_STATUS=published

# ---------- Twitter / X (writing + posting) ----------
# bearer token above is READ-ONLY. To POST tweets you need OAuth 1.0a user
# context credentials. Generate all 4 from a Twitter Developer app's
# "Keys and tokens" tab (free tier: 50 tweets per 15 min).
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_USER_ACCESS_TOKEN=
TWITTER_USER_ACCESS_SECRET=
TWITTER_HANDLE=

# ---------- Email newsletter (Resend) ----------
# Resend: https://resend.com — 100 emails/day free, 10k/month.
# After signup: verify your sending domain (DKIM/SPF in DNS), then
# generate API key and create an Audience to hold your subscriber list.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME=
NEWSLETTER_REPLY_TO=
NEWSLETTER_AUDIENCE_ID=
NEWSLETTER_RATE_LIMIT_PER_SEC=10

# ---------- Webhook publisher (custom CMS / relay / queue) ----------
# POSTs JSON {title, subtitle, tags, body_markdown, cover_image, inline_images,
# metadata} to your endpoint. Receiver returns {published_url|url|link} on
# success; non-2xx fails the publish (auto-retried once via D4).
WEBHOOK_PUBLISH_URL=
# Either a verbatim Authorization value ("Bearer xxx", "Basic ...") OR a
# header:value pair ("X-API-Key:xxxx") — the publisher splits on the first
# colon when it's not Bearer/Basic.
WEBHOOK_AUTH_HEADER=
# When false, images travel as {filename, content_type, local_path} with no
# binary inline. Useful for localhost receivers that share filesystem.
WEBHOOK_INCLUDE_IMAGE_BASE64=true
# Wire format: "json" (default, single JSON body, base64 images) or
# "multipart" (multipart/form-data with raw image bytes — pick this for
# FastAPI / Django / generic CMS endpoints that natively want file uploads).
WEBHOOK_FORMAT=json
# Optional GET endpoint for `af review-publish-stats` after webhook publishing.
# Called with query params: platform_url=<published_url>&post_id=<platform_post_id>.
# Expected JSON can include likes/comments/views/etc.; scrape_status defaults to "ok".
AGENTFLOW_WEBHOOK_STATS_URL=
AGENTFLOW_WEBHOOK_STATS_AUTH_HEADER=

# ---------- Telegram review bot (Gate A/B/C/D HITL) ----------
# Bot token from @BotFather.
# ⚠ IMPORTANT: this is the REVIEW bot token (the one that posts Gate cards
# and receives approve/reject callbacks). It is the same env var name
# regardless of which bot — name "TELEGRAM_BOT_TOKEN" is generic but the
# review daemon is the only consumer in this repo. If you also run a
# notification-only bot, give it a separate env var (not handled here).
TELEGRAM_BOT_TOKEN=
# Operator chat id (single uid). This uid implicitly has all action grants
# (review/write/edit/image/publish/*) and is unrevocable. Get yours by
# /start-ing the bot once — the daemon's first /start will log the chat_id;
# or via @userinfobot. For multi-operator setups use:
#   af review-auth-add <uid> --actions review,edit
TELEGRAM_REVIEW_CHAT_ID=
# Polling interval (seconds) for the long-poll loop in local mode.
TELEGRAM_POLL_INTERVAL_SECONDS=5

# ---------- External agent bridge ----------
# Optional read token for `af review-dashboard` GET endpoints.
REVIEW_DASHBOARD_TOKEN=
# Best-effort outbound event fan-out. AgentFlow emits memory/gate/publish/API
# events to this URL as normalized JSON envelopes.
AGENTFLOW_AGENT_EVENT_WEBHOOK_URL=
# Same auth-header semantics as the webhook publisher:
#   Bearer xxx    -> Authorization: Bearer xxx
#   X-API-Key:xxx -> X-API-Key: xxx
AGENTFLOW_AGENT_EVENT_AUTH_HEADER=
# Required for POST /api/commands on the agent bridge.
AGENTFLOW_AGENT_BRIDGE_TOKEN=
# Keep false unless you explicitly want external agents to call dangerous
# commands like `publish` or `review-publish-mark`.
AGENTFLOW_AGENT_BRIDGE_ENABLE_DANGEROUS=false

# ---------- v0.5 optional (not used in v0.1) ----------
# Substack (browser auth), WeChat Official Account, X long-form
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
X_API_KEY=
X_API_SECRET=

# Newsletter IMAP (v0.5)
NEWSLETTER_EMAIL=
NEWSLETTER_APP_PASSWORD=
